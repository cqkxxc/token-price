---
import Base from '../layouts/Base.astro';
import { META, STABILITY } from '../lib/data';
import { monitorIndexJsonLd } from '../lib/seo';

type StabilityRecord = (typeof STABILITY)[number] & {
  response_text?: string | null;
  source_url?: string | null;
};
type MonitorStatus = StabilityRecord['status'];

const isVerified = (record: StabilityRecord) => Boolean(
  record.last_checked_at
  && record.source_url
  && (
    record.uptime_7d != null
    || record.avg_latency_ms != null
    || record.last_response_time_ms != null
  )
);

const average = (values: Array<number | null | undefined>) => {
  const valid = values.filter((value): value is number => Number.isFinite(value));
  return valid.length ? valid.reduce((sum, value) => sum + value, 0) / valid.length : null;
};

const aggregateStatus = (records: StabilityRecord[]): MonitorStatus => {
  if (records.some((record) => record.status === 'offline')) return 'offline';
  if (records.some((record) => record.status === 'degraded')) return 'degraded';
  if (records.some((record) => record.status === 'online')) return 'online';
  return 'unknown';
};

const statusLabel = (status: MonitorStatus) => ({
  online: '已验证正常',
  degraded: '存在波动线路',
  offline: '发现离线线路',
  unknown: '状态待确认',
}[status]);

const formatTime = (value: string | null | undefined) => {
  if (!value) return '—';
  const date = new Date(value);
  if (Number.isNaN(date.getTime())) return '—';
  return new Intl.DateTimeFormat('zh-CN', {
    timeZone: 'Asia/Shanghai',
    month: '2-digit',
    day: '2-digit',
    hour: '2-digit',
    minute: '2-digit',
    hour12: false,
  }).format(date);
};

const recordsBySupplier = new Map<string, StabilityRecord[]>();
for (const record of (STABILITY as StabilityRecord[]).filter(isVerified)) {
  const records = recordsBySupplier.get(record.supplier_slug) ?? [];
  records.push(record);
  recordsBySupplier.set(record.supplier_slug, records);
}

const suppliers = Array.from(recordsBySupplier, ([slug, records]) => {
  const latestCheckedAt = records
    .map((record) => record.last_checked_at)
    .filter((value): value is string => Boolean(value))
    .sort((left, right) => Date.parse(right) - Date.parse(left))[0] ?? null;
  return {
    slug,
    name: records[0]?.supplier_name || slug,
    status: aggregateStatus(records),
    stability: average(records.map((record) => record.uptime_7d)),
    latency: average(records.map((record) => record.last_response_time_ms ?? record.avg_latency_ms)),
    modelCount: new Set(records.map((record) => record.model_slug)).size,
    routeCount: new Set(records.map((record) => `${record.canonical_id}::${record.route}`)).size,
    latestCheckedAt,
  };
}).sort((left, right) => left.name.localeCompare(right.name, 'zh-CN'));

const statusCounts = {
  online: suppliers.filter((supplier) => supplier.status === 'online').length,
  degraded: suppliers.filter((supplier) => supplier.status === 'degraded').length,
  offline: suppliers.filter((supplier) => supplier.status === 'offline').length,
  unknown: suppliers.filter((supplier) => supplier.status === 'unknown').length,
};

const description = '查看供应商各模型线路的上游近 7 天监控稳定率、响应延迟和最近更新时间；缺少可追溯来源时不会展示推测数据。';
const jsonLd = monitorIndexJsonLd(
  Astro.site || new URL(Astro.url.origin),
  suppliers,
  description,
  META.data_updated_at,
);
---
<Base title="供应商可用性监控 — AI 模型比价" description={description} jsonLd={jsonLd}>
  <div class="page active">
    <div class="page-container monitor-page">
      <a class="back-link" href="/">← 返回模型比价</a>
      <header class="monitor-page-header">
        <p class="monitor-kicker">VERIFIED ROUTE TELEMETRY</p>
        <h1>供应商<em>可用性监控</em></h1>
        <p>{description}</p>
      </header>

      {suppliers.length > 0 ? (
        <>
          <div class="monitor-summary" aria-label="供应商状态汇总">
            <div class="monitor-stat"><span class="status-dot online" aria-hidden="true"></span> 已验证正常 <strong>{statusCounts.online}</strong></div>
            <div class="monitor-stat"><span class="status-dot degraded" aria-hidden="true"></span> 存在波动 <strong>{statusCounts.degraded}</strong></div>
            <div class="monitor-stat"><span class="status-dot offline" aria-hidden="true"></span> 发现离线 <strong>{statusCounts.offline}</strong></div>
            <div class="monitor-stat"><span class="status-dot unknown" aria-hidden="true"></span> 状态待确认 <strong>{statusCounts.unknown}</strong></div>
          </div>

          <div class="monitor-grid">
            {suppliers.map((supplier) => (
              <a
                class={`monitor-card ${supplier.status}`}
                href={`/monitor/${encodeURIComponent(supplier.slug)}/`}
                aria-label={`查看 ${supplier.name} 的上游近 7 天线路监控详情`}
              >
                <div class="monitor-card-heading">
                  <span class="monitor-card-name">{supplier.name}</span>
                  <span class="monitor-card-arrow" aria-hidden="true">↗</span>
                </div>
                <div class="monitor-card-stats">
                  <div class="monitor-card-stat"><span class="monitor-card-stat-label">线路状态</span><span class={`status-text ${supplier.status}`}>{statusLabel(supplier.status)}</span></div>
                  <div class="monitor-card-stat"><span class="monitor-card-stat-label">近 7 天平均稳定率</span><span class="monitor-card-stat-value">{supplier.stability != null ? `${supplier.stability.toFixed(2)}%` : '—'}</span></div>
                  <div class="monitor-card-stat"><span class="monitor-card-stat-label">平均响应延迟</span><span class="monitor-card-latency">{supplier.latency != null ? `${Math.round(supplier.latency)}ms` : '—'}</span></div>
                  <div class="monitor-card-stat"><span class="monitor-card-stat-label">已验证范围</span><span>{supplier.modelCount} 个模型 · {supplier.routeCount} 条线路</span></div>
                  <div class="monitor-card-stat"><span class="monitor-card-stat-label">最近更新</span><time datetime={supplier.latestCheckedAt || undefined}>{formatTime(supplier.latestCheckedAt)}</time></div>
                </div>
              </a>
            ))}
          </div>
        </>
      ) : (
        <section class="empty-state monitor-empty" aria-labelledby="monitorEmptyTitle">
          <h2 id="monitorEmptyTitle">暂无已验证监控数据</h2>
          <p>上游尚未返回带来源链接的近 7 天监控记录，因此这里不展示模拟状态。</p>
        </section>
      )}
    </div>
  </div>
</Base>
