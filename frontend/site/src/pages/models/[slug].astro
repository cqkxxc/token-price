---
import Base from '../../layouts/Base.astro';
import { MODELS, MANIFEST, META, pricesOf, stabilityOf } from '../../lib/data';
import {
  modelLogo, companyName, activePrices, officialPriceDisplay, priceTableHTML, esc,
} from '../../lib/render';
import { modelJsonLd } from '../../lib/seo';

export function getStaticPaths() {
  return MODELS.map((m) => ({ params: { slug: m.slug }, props: { model: m } }));
}

const { model: m } = Astro.props;
const ps = activePrices(pricesOf(m.canonical_id));
const supplierCount = new Set(ps.map((price) => price.supplier_slug)).size;
const official = officialPriceDisplay(m);
const desc = m.description
  ? m.description.slice(0, 140)
  : `${m.display_name} 官方价格与各中转站报价对比。`;
const header = modelLogo(m, MANIFEST, 'model-avatar-lg');
const priceTable = ps.length
  ? priceTableHTML(m, pricesOf(m.canonical_id), stabilityOf(m.canonical_id))
  : '';
const jsonLd = modelJsonLd(
  Astro.site || new URL(Astro.url.origin),
  m,
  pricesOf(m.canonical_id),
  META.data_updated_at,
);
---
<Base title={`${m.display_name} 价格比价 — 官方价与中转站对比`} description={desc} jsonLd={jsonLd}>
  <div class="page active">
    <div class="page-container" style="padding-top:32px">
      <a class="back-link" href="/">← 返回比价列表</a>
      <div class="detail-card">
        <div class="drawer-model-header" set:html={header + `<div><h1 class="drawer-model-name">${esc(m.display_name)}</h1><div class="drawer-model-meta">${esc(companyName(m))} · ${(m.capabilities || []).map(esc).join(' · ')} · ${esc(m.context_window || '上下文未提供')} · ${supplierCount} 家供应商 · ${ps.length} 条报价线路</div></div>`}></div>
        {m.description && <p class="model-description">{m.description}</p>}
        <div class="price-summary" style="margin-top:20px">
          <div><small>{official.primaryLabel}</small><div class="price-cell" set:html={official.primaryHtml}></div></div>
          <div><small>官方输出价</small><div class="price-cell" set:html={official.outputHtml}></div></div>
          <div><small>官方综合价</small><div class="price-cell" set:html={official.compositeHtml}></div></div>
        </div>
        <h2 class="drawer-section-title">供应商比价（{supplierCount} 家 · {ps.length} 条线路）</h2>
        {ps.length ? (
          <div class="table-wrap" set:html={priceTable}></div>
        ) : (
          <section class="verified-quotes-empty" aria-labelledby="verifiedQuotesEmptyTitle">
            <h2 id="verifiedQuotesEmptyTitle">暂无已验证报价</h2>
            <p>当前数据快照没有有效的供应商报价，页面不会使用估算价格补齐。</p>
          </section>
        )}
      </div>
    </div>
  </div>
</Base>
