---
import Base from '../layouts/Base.astro';
import { MODELS, PRICES, SUPPLIERS, MANIFEST, META, pricesOf, clientDataset } from '../lib/data';
import { rowHTML, modelLogo, companyName, composite, num } from '../lib/render';

// ── 首屏筛选器数据（构建期计算）────────────────────────
const companies = [...new Map(MODELS.map((m) => [m.company.slug, companyName(m)])).entries()];
const capabilities = [...new Set(MODELS.flatMap((m) => m.capabilities || []))];

// 默认排序：综合价降序（与旧版一致）
const sorted = [...MODELS].sort((a, b) => (composite(b) ?? -Infinity) - (composite(a) ?? -Infinity));
const initialRows = sorted.map((m) => rowHTML(m, pricesOf(m.canonical_id), MANIFEST)).join('');

// 热门模型走马灯
const hotScrollModels = [
  { slug: 'gpt-5.5' }, { slug: 'claude-sonnet-5' }, { slug: 'gpt-5.6-sol' },
  { slug: 'grok-4.5' }, { slug: 'deepseek-v4-pro' }, { slug: 'glm-5.2' }, { slug: 'kimi-k2.7-code' },
];
const hotCards = hotScrollModels
  .map((h) => {
    const m = MODELS.find((x) => x.slug === h.slug);
    if (!m) return '';
    return `<button class="hot-model-card" type="button" data-hot-model="${m.slug}" aria-pressed="false">${modelLogo(m, MANIFEST, 'hot-model-logo')}<span>${m.display_name}</span></button>`;
  })
  .join('');

const updatedAt = String(META.data_updated_at || '');
const updated = updatedAt.slice(0, 10);
const activeQuoteCount = PRICES.filter((p) => p.is_active === true && p.source_url).length;
const dataset = JSON.stringify(clientDataset()).replace(/</g, '\\u003c');
---
<Base title="AI 模型价格比价 — 官方价与中转站价格对比" active="home">
  <div id="page-home" class="page active">
    <header class="page-intro">
      <div class="hero-effects" aria-hidden="true">
        <span class="hero-orb hero-orb-primary"></span>
        <span class="hero-orb hero-orb-secondary"></span>
        <span class="hero-scan"></span>
      </div>
      <div class="hero-copy">
        <div class="intro-eyebrow">
          <span class="pulse-dot"></span>
          <span>实时价格指数</span>
          <span class="intro-eyebrow-separator" aria-hidden="true"></span>
          <span class="intro-eyebrow-en">LIVE PRICING INDEX</span>
        </div>
        <h1>AI 大模型全网比价</h1>
        <p>覆盖主流官方厂商与中转站。统一人民币口径，一目了然。</p>
      </div>
      <aside class="hero-snapshot" aria-label="市场数据概览">
        <div class="hero-snapshot-heading">
          <span>市场数据概览</span>
          <span class="hero-snapshot-code">MARKET SNAPSHOT</span>
        </div>
        <dl class="hero-metrics">
          <div class="hero-metric">
            <dt>收录模型</dt>
            <dd><strong>{MODELS.length}</strong><small>MODELS</small></dd>
          </div>
          <div class="hero-metric">
            <dt>供应商</dt>
            <dd><strong>{SUPPLIERS.length}</strong><small>SUPPLIERS</small></dd>
          </div>
          <div class="hero-metric">
            <dt>有效报价</dt>
            <dd><strong>{activeQuoteCount}</strong><small>QUOTES</small></dd>
          </div>
          <div class="hero-metric hero-metric-date">
            <dt>数据更新</dt>
            <dd><time datetime={updatedAt}>{updated || '—'}</time><small>UPDATED</small></dd>
          </div>
        </dl>
      </aside>
    </header>

    <section class="hot-models" aria-labelledby="hotModelsTitle">
      <div class="hot-models-label">
        <span class="hot-models-signal" aria-hidden="true"></span>
        <span><strong id="hotModelsTitle">热门模型</strong><small>TRENDING NOW</small></span>
      </div>
      <span class="hot-models-divider" aria-hidden="true"></span>
      <div class="hot-models-viewport"><div class="hot-models-track" id="hotModelsTrack">
        <div class="hot-models-marquee">
          <div class="hot-models-group" set:html={hotCards}></div>
          <div class="hot-models-group" aria-hidden="true" inert set:html={hotCards}></div>
        </div>
      </div></div>
    </section>

    <section class="content-shell" aria-labelledby="filterHeading">
      <div class="filter-panel">
        <div class="filter-heading">
          <div class="filter-heading-title">
            <span class="filter-kicker">MODEL EXPLORER</span>
            <h2 id="filterHeading">筛选模型</h2>
          </div>
          <div class="filter-search" id="searchBox">
            <svg class="filter-search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"></circle><path d="m21 21-4.3-4.3"></path></svg>
            <input type="text" id="globalSearch" placeholder="搜索模型名称、厂商、能力…" autocomplete="off" aria-label="搜索模型">
          </div>
          <span id="resultsInfo" aria-live="polite">共 {MODELS.length} 个模型 · {updated}</span>
        </div>
        <div class="filter-controls">
          <div class="filter-row"><span class="filter-label">厂商</span>
            <div class="filter-group" id="companyChips">
              <button type="button" class="chip active" data-company="">全部</button>
              {companies.map(([slug, name]) => <button type="button" class="chip" data-company={slug}>{name}</button>)}
            </div>
          </div>
          <div class="filter-row"><span class="filter-label">能力</span>
            <div class="filter-group" id="capabilityChips">
              <button type="button" class="chip active" data-capability="">全部</button>
              {capabilities.map((c) => <button type="button" class="chip" data-capability={c}>{c}</button>)}
            </div>
          </div>
        </div>
      </div>

      <div class="table-wrap"><div class="table-scroll"><table class="model-table"><caption class="sr-only">AI 模型官方价格与供应商报价对比</caption><thead><tr>
        <th class="sortable" data-sort="name" id="th-name" scope="col"><button type="button" class="sort-control"><span>模型</span><i class="sort-arrow" aria-hidden="true"></i></button></th>
        <th scope="col">厂商</th><th scope="col">能力</th>
        <th class="sortable" data-sort="input_price" id="th-input" scope="col"><button type="button" class="sort-control"><span>输入价</span><i class="sort-arrow" aria-hidden="true"></i></button></th>
        <th class="sortable" data-sort="output_price" id="th-output" scope="col"><button type="button" class="sort-control"><span>输出价</span><i class="sort-arrow" aria-hidden="true"></i></button></th>
        <th class="sortable active desc" data-sort="composite_price" id="th-composite" scope="col"><button type="button" class="sort-control"><span>综合价</span><i class="sort-arrow" aria-hidden="true"></i></button></th>
        <th scope="col">折扣</th><th scope="col">渠道</th><th scope="col"><span class="sr-only">操作</span></th>
      </tr></thead><tbody id="tableBody" set:html={initialRows}></tbody></table></div>
        <div class="empty-state" id="emptyState" style="display:none">没有匹配的模型</div>
      </div>
    </section>
  </div>

  <!-- 比价抽屉 -->
  <div class="drawer-overlay" id="drawerOverlay"></div>
  <div class="drawer" id="drawer">
    <button type="button" class="btn-drawer-close" id="drawerClose" aria-label="关闭比价抽屉">✕</button>
    <div class="drawer-inner" id="drawerContent"></div>
  </div>

  <script id="__DATA__" type="application/json" set:html={dataset}></script>
  <script src="../scripts/home.ts"></script>
</Base>
